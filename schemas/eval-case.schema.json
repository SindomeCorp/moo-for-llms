{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/moo-for-llms/eval-case.schema.json",
  "title": "MOO Eval Case",
  "type": "object",
  "required": ["id", "kind", "dialect", "prompt", "source", "license", "reviewed"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "kind": { "type": "string", "enum": ["syntax", "bugfix", "codegen"] },
    "dialect": {
      "type": "string",
      "enum": ["portable", "lambdamoo", "stunt", "toaststunt", "core-specific", "patch-specific"]
    },
    "prompt": { "type": "string", "minLength": 1 },
    "input": { "type": "string" },
    "expected": { "type": "string" },
    "expected_properties": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gold_answer": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["contains", "not_contains", "regex", "not_regex"]
          },
          "value": { "type": "string", "minLength": 1 },
          "points": { "type": "number", "exclusiveMinimum": 0 },
          "label": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "negative_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requires_code": { "type": "boolean" },
    "compile_check": { "type": "boolean" },
    "source": {
      "type": "string",
      "enum": [
        "original",
        "manual-summary",
        "curated-public",
        "approved-generic-sindome"
      ]
    },
    "license": { "type": "string", "minLength": 1 },
    "reviewed": { "type": "boolean" }
  },
  "additionalProperties": false,
  "anyOf": [
    { "required": ["expected"] },
    { "required": ["expected_properties"] }
  ]
}
